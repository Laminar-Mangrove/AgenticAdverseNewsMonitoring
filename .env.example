# Adverse News Classifier - Environment Variables

# LLM Backend (choose one)
# Option 1: Ollama - free, local (default for local dev only)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Option 2: OpenRouter - recommended for hosted Streamlit apps
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=openai/gpt-4o-mini

# Supabase (required for email login + per-user credits)
# 1. Create project at https://supabase.com
# 2. Run scripts/supabase_schema.sql in the SQL editor
# 3. Authentication → Providers → Email: enable
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# OpenSanctions API (commercial use — required for hosted/paid app)
# Get a 30-day trial key at https://www.opensanctions.org/api/
# If not set, falls back to local CSV files (non-commercial only).
OPENSANCTIONS_API_KEY=

# Cloudflare Turnstile CAPTCHA (recommended for production)
# Create keys at https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Stripe Payment Gateway
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_ENTERPRISE=price_xxx

# Optional: Payment Links (cannot attach user_id — use Stripe Checkout for logged-in purchases)
# STRIPE_LINK_STARTER=https://buy.stripe.com/xxx

# Optional: Stripe webhook (production)
STRIPE_WEBHOOK_SECRET=whsec_...

# App URL for Stripe redirect (production)
BASE_URL=https://your-app.streamlit.app
