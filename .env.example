# Adverse News Classifier - Environment Variables

# LLM Backend (choose one)
# Option 1: Ollama - free, local (default)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Option 2: OpenRouter - for GPT, Gemini, etc.
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=openai/gpt-4o-mini

# Stripe Payment Gateway
# Create products at https://dashboard.stripe.com/products
# Then set price IDs (price_xxx) for each credit pack
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_ENTERPRISE=price_xxx

# Optional: For Stripe webhook (production)
STRIPE_WEBHOOK_SECRET=whsec_...

# App URL for Stripe redirect (production)
BASE_URL=https://your-app.streamlit.app
